# Database Configuration
MONGODB_URI=mongodb://localhost:27017/semantask

# Redis Configuration
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Authentication Secrets
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
INTERNAL_SECRET=your_internal_secret_for_service_communication
COOKIE_DOMAIN=

# NextAuth Configuration
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ImageKit Configuration (Media Upload)
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
NEXT_PUBLIC_PUBLIC_KEY=your_imagekit_public_key
NEXT_PUBLIC_URI_ENDPOINT=https://ik.imagekit.io/your_account_id

# SMTP Configuration (Email Service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_password
EMAIL_USER=your_email@gmail.com
EMAIL_SENDER_NAME=Chat App

# Server Configuration
NODE_ENV=development
ORIGIN=http://localhost:3000,http://localhost:3001
WEB_SERVER_URL=http://localhost:3000
SOCKET_SERVER_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# VPS / Docker Compose production example (semantask.com):
# NODE_ENV=production
# ORIGIN=https://semantask.com
# APP_URL=https://semantask.com
# NEXT_PUBLIC_APP_URL=https://semantask.com
# COOKIE_DOMAIN=.semantask.com
# Do NOT set NEXT_PUBLIC_SOCKET_URL — nginx proxies /api/socket on the same host.
# REDIS_URL / SOCKET_SERVER_URL are overridden by docker-compose.yml for in-stack Redis/socket.
# Google OAuth redirect URIs are derived from request Host + X-Forwarded-Proto on the server.
# Rebuild nextapp after changing NEXT_PUBLIC_APP_URL: docker compose build --no-cache nextapp

# App Configuration
APP_NAME=Chat App

# Next.js Public Variables (prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Task Worker / LLM Configuration
LLM_PROVIDER=openai-compatible

LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your_api_key_here

TASK_AGENT_MODEL=qwen3.5-coder-32b

TASK_AGENT_LLM_TIMEOUT_MS=45000

LLM_SUPPORTS_RESPONSES_API=false
LLM_SUPPORTS_JSON_MODE=false
LLM_SUPPORTS_STRUCTURED_OUTPUTS=true
LLM_SUPPORTS_TOOL_CALLING=true
LLM_SUPPORTS_STREAMING=true

# Tool-specific API keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=Chat App <noreply@example.com>

# Task worker policy (production: set explicit domains before enabling send_email)
# TASK_WORKER_ALLOWED_EMAIL_DOMAINS=example.com,mail.example.com
# ALLOWED_EMAIL_DOMAINS=example.com

# Execution FSM shadow mode (default on; set to 0 to disable shadow writes)
# TASK_EXECUTION_FSM_SHADOW_MODE=1

# Log when Task.lifecycleState disagrees with deriveLegacyLifecycleState(executionState)
# TASK_STATE_DIVERGENCE_CHECK=1

# Emit POLICY_BLOCKED / POLICY_APPROVAL_REQUIRED shadow FSM events on policy early returns
# and align legacy lifecycleState with the FSM projection (requires FSM shadow mode on)
# TASK_POLICY_SHADOW_EMIT=1

# Emit RETRY_DUE on retry scanner promote (requires FSM shadow mode on)
# TASK_RETRY_SHADOW_EMIT=1

# Message ingress classifier: regex (default) | shadow | llm
# TASK_CLASSIFIER_MODE=regex
# TASK_CLASSIFIER_THRESHOLD=0.7
# TASK_CLASSIFIER_MODEL=gpt-4o-mini
# TASK_CLASSIFIER_LLM_TIMEOUT_MS=3000

# Stuck task detector: log (default) | fail | retry
# TASK_STUCK_REMEDIATION=log
# TASK_STUCK_HEARTBEAT_MS=20000
# TASK_STUCK_DETECTION_INTERVAL_MS=60000

# Task cancellation is always available via POST /api/tasks/:id/cancel when not terminal.
