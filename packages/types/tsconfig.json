{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": "../..",
        "ignoreDeprecations": "5.0",
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}