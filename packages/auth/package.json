{
  "name": "@semantask/auth",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run -c vitest.config.ts --project unit && vitest run -c vitest.config.ts --project integration --no-file-parallelism --max-workers=1",
    "test:integration": "vitest run -c vitest.config.ts --project integration --no-file-parallelism --max-workers=1",
    "test:download-mongo": "node --import tsx ./__tests__/helpers/download-mongo-binary.mts",
    "teypecheck": "tsc --noEmit",
    "test:watch": "vitest -c vitest.config.ts"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.2"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "vitest": "^3.2.6"
  }
}