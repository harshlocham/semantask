{
    "compilerOptions": {
        "baseUrl": ".",
        "ignoreDeprecations": "5.0",
        "paths": {
            "@chat/db/models/*": [
                "../db/models/*.ts"
            ],
            "@/models/*": [
                "../db/models/*"
            ],
            "@/lib/Db/*": [
                "../db/*"
            ],
            "@/lib/services/*": [
                "./*"
            ],
            "@/lib/repositories/*": [
                "./repositories/*"
            ],
            "@/lib/validators/*": [
                "./validators/*"
            ],
            "@chat/services/*": [
                "./*"
            ],
            "@chat/services/validators/*": [
                "./validators/*"
            ],
            "@/server/normalizers/*": [
                "./normalizers/*"
            ]
        },
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "strict": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "__tests__",
        "jest.config.cjs"
    ]
}
