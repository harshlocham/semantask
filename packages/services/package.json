{
    "name": "@semantask/services",
    "version": "3.2.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./outbox.service": {
            "import": "./dist/services/outbox.service.js",
            "types": "./dist/services/outbox.service.d.ts",
            "default": "./dist/services/outbox.service.js"
        },
        "./outbox-metrics.service": {
            "import": "./dist/services/outbox-metrics.service.js",
            "types": "./dist/services/outbox-metrics.service.d.ts",
            "default": "./dist/services/outbox-metrics.service.js"
        },
        "./execution-event.service": {
            "import": "./dist/services/execution-event.service.js",
            "types": "./dist/services/execution-event.service.d.ts",
            "default": "./dist/services/execution-event.service.js"
        },
        "./task-intelligence.service": {
            "import": "./dist/services/task-intelligence.service.js",
            "types": "./dist/services/task-intelligence.service.d.ts",
            "default": "./dist/services/task-intelligence.service.js"
        },
        "./message-classifier.service": {
            "import": "./dist/services/message-classifier.service.js",
            "types": "./dist/services/message-classifier.service.d.ts",
            "default": "./dist/services/message-classifier.service.js"
        },
        "./message-intent.service": {
            "import": "./dist/services/message-intent.service.js",
            "types": "./dist/services/message-intent.service.d.ts",
            "default": "./dist/services/message-intent.service.js"
        },
        "./authorization.service": {
            "import": "./dist/services/authorization.service.js",
            "types": "./dist/services/authorization.service.d.ts",
            "default": "./dist/services/authorization.service.js"
        },
        "./organization.service": {
            "import": "./dist/services/organization.service.js",
            "types": "./dist/services/organization.service.d.ts",
            "default": "./dist/services/organization.service.js"
        },
        "./organization-errors": {
            "import": "./dist/services/organization-errors.js",
            "types": "./dist/services/organization-errors.d.ts",
            "default": "./dist/services/organization-errors.js"
        },
        "./organization-quota.service": {
            "import": "./dist/services/organization-quota.service.js",
            "types": "./dist/services/organization-quota.service.d.ts",
            "default": "./dist/services/organization-quota.service.js"
        },
        "./organization-policy.service": {
            "import": "./dist/services/organization-policy.service.js",
            "types": "./dist/services/organization-policy.service.d.ts",
            "default": "./dist/services/organization-policy.service.js"
        },
        "./usage-event.service": {
            "import": "./dist/services/usage-event.service.js",
            "types": "./dist/services/usage-event.service.d.ts",
            "default": "./dist/services/usage-event.service.js"
        },
        "./tool-grant.service": {
            "import": "./dist/services/tool-grant.service.js",
            "types": "./dist/services/tool-grant.service.d.ts",
            "default": "./dist/services/tool-grant.service.js"
        },
        "./execution-audit.service": {
            "import": "./dist/services/execution-audit.service.js",
            "types": "./dist/services/execution-audit.service.d.ts",
            "default": "./dist/services/execution-audit.service.js"
        },
        "./repositories/task.repo": {
            "import": "./dist/services/repositories/task.repo.js",
            "types": "./dist/services/repositories/task.repo.d.ts",
            "default": "./dist/services/repositories/task.repo.js"
        },
        "./contact.service": {
            "import": "./dist/services/contact.service.js",
            "types": "./dist/services/contact.service.d.ts",
            "default": "./dist/services/contact.service.js"
        },
        "./tool-normalizers": {
            "import": "./dist/services/tool-normalizers.js",
            "types": "./dist/services/tool-normalizers.d.ts",
            "default": "./dist/services/tool-normalizers.js"
        },
        "./mongo-transaction": {
            "import": "./dist/services/mongo-transaction.js",
            "types": "./dist/services/mongo-transaction.d.ts",
            "default": "./dist/services/mongo-transaction.js"
        },
        "./validators/*": {
            "import": "./dist/validators/*.js",
            "types": "./dist/validators/*.d.ts",
            "default": "./dist/validators/*.js"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts",
            "default": "./dist/*.js"
        },
        "./repositories/*": {
            "import": "./dist/repositories/*.js",
            "types": "./dist/repositories/*.d.ts",
            "default": "./dist/repositories/*.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && node ./scripts/postbuild-fix.cjs && node ./scripts/postbuild-resolve-imports.cjs",
        "typecheck": "tsc --noEmit",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest.config.cjs"
    },
    "devDependencies": {
        "@jest/globals": "30.4.1",
        "@types/jest": "^30.0.0",
        "jest": "^30.4.1",
        "ts-jest": "^29.4.4"
    },
    "dependencies": {
        "@semantask/db": "workspace:*",
        "@semantask/observability": "workspace:*",
        "@semantask/types": "workspace:*",
        "mongoose": "^8.24.0",
        "zod": "^4.0.5"
    }
}