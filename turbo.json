{
    "globalEnv": [
        "NODE_ENV",
        "APP_NAME",
        "MONGODB_URI",
        "ACCESS_TOKEN_SECRET",
        "REFRESH_TOKEN_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "IMAGEKIT_PRIVATE_KEY",
        "IMAGEKIT_PUBLIC_KEY",
        "INTERNAL_SECRET",
        "ORIGIN",
        "REDIS_URL",
        "UPSTASH_REDIS_REST_URL",
        "UPSTASH_REDIS_REST_TOKEN",
        "SOCKET_SERVER_URL",
        "SMTP_*",
        "EMAIL_*",
        "NEXT_PUBLIC_*"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "dev": {
            "cache": false
        },
        "start": {
            "dependsOn": [
                "build",
                "^build"
            ],
            "cache": false
        },
        "test": {
            "dependsOn": [
                "^test"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ],
            "outputs": []
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "outputs": []
        },
        "clean": {
            "cache": false
        }
    }
}