{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/models/*": [
        "./packages/db/models/*"
      ],
      "@/lib/Db/*": [
        "./packages/db/*"
      ],
      "@/lib/services/*": [
        "./packages/services/*"
      ],
      "@semantask/services/*": [
        "./packages/services/*"
      ],
      "@semantask/db/models/*": [
        "./packages/db/models/*.ts"
      ],
      "@/lib/repositories/*": [
        "./packages/services/repositories/*"
      ],
      "@/lib/validators/*": [
        "./packages/services/validators/*"
      ],
      "@/server/normalizers/*": [
        "./packages/services/normalizers/*"
      ],
      "@/lib/socket/controllers/*": [
        "./apps/socket/server/socket/controllers/*"
      ],
      "@/lib/socket/*": [
        "./apps/web/hooks/*"
      ],
      "@/lib/hooks/*": [
        "./apps/web/hooks/*"
      ],
      "@/lib/utils/*": [
        "./apps/web/lib/utils/*"
      ],
      "@/*": [
        "./apps/web/*",
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "types/**/*.d.ts",
    "server.js",
    "types"
  ],
  "exclude": [
    "node_modules"
  ]
}